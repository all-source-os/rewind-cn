# Rewind configuration

project_name = "my-project"

# Agent configuration — uncomment to enable LLM-powered plan & execute
# [agent]
# provider = "anthropic"
# api_key_env = "ANTHROPIC_API_KEY"
#
# [agent.planner]
# model = "claude-sonnet-4-5-20250514"
#
# [agent.coder]
# model = "claude-sonnet-4-5-20250514"
# max_tokens = 16384
#
# [agent.evaluator]
# model = "claude-haiku-4-5-20251001"

[execution]
max_concurrent = 3
timeout_secs = 300
max_retries = 2

# Anonymous telemetry via PostHog — disabled by default
# No PII is ever sent: only event counts, durations, error types, and model names.
# [telemetry]
# enabled = true
# posthog_key = "phc_your_project_key"
# posthog_host = "https://us.i.posthog.com"  # or your self-hosted instance
